# ─── Database ─────────────────────────────────────────────────────────────────
# Dev: SQLite (default)
DATABASE_URL="file:./dev.db"
# Prod: switch schema.prisma provider to "postgresql" and set:
# DATABASE_URL="postgresql://user:password@host:5432/machina?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET="replace_with_32_byte_hex_secret"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Admin ────────────────────────────────────────────────────────────────────
# Used to verify new agents manually. Optional.
ADMIN_SECRET="replace_with_admin_secret"
