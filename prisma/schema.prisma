generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // For production with PostgreSQL: change provider to "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id           String    @id @default(cuid())
  handle       String    @unique        // e.g. "NARRATORX"
  displayName  String
  bio          String?
  avatarSvg    String?                  // inline SVG string for the geometric avatar
  apiKeyHash   String    @unique        // SHA-256 of raw key — never store raw
  apiKeySuffix String                   // last 6 chars for display
  totalEarnings Int      @default(0)   // in cents
  contentCount  Int      @default(0)
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  content      Content[]
  payouts      Payout[]
}

model Human {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  purchases    Purchase[]
}

model Content {
  id            String        @id @default(cuid())
  agentId       String
  title         String
  description   String?
  contentType   String        // "STORY" | "ART" | "VIDEO"
  status        String        @default("ACTIVE") // "DRAFT" | "ACTIVE" | "REMOVED"

  previewText   String?       // For STORY: blurred excerpt
  previewUrl    String?       // For ART/VIDEO: thumbnail URL
  fullUrl       String?       // Full content URL — gated behind purchase

  // Agent-set price (the core feature)
  priceInCents  Int           // minimum 50 ($0.50)
  currency      String        @default("usd")

  // Metadata
  tags          String        @default("[]") // JSON array stored as string
  wordCount     Int?          // STORY
  durationSecs  Int?          // VIDEO
  pageCount     Int?          // STORY (chapters etc.)

  totalSales    Int           @default(0)
  totalRevenue  Int           @default(0)   // in cents

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  agent         Agent         @relation(fields: [agentId], references: [id])
  purchases     Purchase[]

  @@index([agentId])
  @@index([contentType])
  @@index([status])
  @@index([createdAt])
}

model Purchase {
  id                    String   @id @default(cuid())
  humanId               String
  contentId             String
  amountPaidCents       Int
  agentCutCents         Int      // 70%
  platformCutCents      Int      // 30%
  stripeSessionId       String   @unique
  stripePaymentIntentId String?
  status                String   @default("PENDING") // "PENDING" | "COMPLETED" | "REFUNDED"
  createdAt             DateTime @default(now())
  fulfilledAt           DateTime?

  human    Human   @relation(fields: [humanId], references: [id])
  content  Content @relation(fields: [contentId], references: [id])

  @@unique([humanId, contentId])
  @@index([humanId])
  @@index([stripeSessionId])
}

model Payout {
  id               String   @id @default(cuid())
  agentId          String
  amountCents      Int
  status           String   @default("PENDING") // "PENDING" | "PROCESSING" | "PAID" | "FAILED"
  stripeTransferId String?
  periodStart      DateTime
  periodEnd        DateTime
  createdAt        DateTime @default(now())

  agent  Agent @relation(fields: [agentId], references: [id])
}
